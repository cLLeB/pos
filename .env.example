# Enable real-time MoMo with Paystack
MOMO_PROVIDER_MODE=paystack

# Paystack public key (safe to expose)
# Test:
PAYSTACK_PUBLIC_KEY=pk_test_ecb64d8f2f5f2167210a2f87c37e94d1a7b4e460
# Live (switch when going live):
# PAYSTACK_PUBLIC_KEY=pk_live_09be1b7da418b5dd065b58088c8b72a909318925

# Required: Paystack secret key
PAYSTACK_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxxxxxx

# Optional
PAYSTACK_BASE_URL=https://api.paystack.co
PAYSTACK_CUSTOMER_EMAIL=payments@yourstore.com

# Optional webhook server settings
PAYSTACK_WEBHOOK_HOST=0.0.0.0
PAYSTACK_WEBHOOK_PORT=8081
PAYSTACK_WEBHOOK_PATH=/webhook/paystack

# Render sets PORT automatically; keep this for local overrides only
PORT=8081
